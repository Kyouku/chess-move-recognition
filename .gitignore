# ============================
# PYTHON / BUILD ARTIFACTS
# ============================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
.eggs/
*.egg-info/
*.manifest
*.spec

# Test and coverage
htmlcov/
.tox/
.coverage*
.cache/
.pytest_cache/
.mypy_cache/
.pytype/
.dmypy.json

# Environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ============================
# JUPYTER / NOTEBOOKS
# ============================
.ipynb_checkpoints/
*.nbconvert.ipynb
notebooks/.ipynb_checkpoints/
notebooks/.ipynb_cache/

# ============================
# DATA AND MODELS
# ============================
# Large or local only data that should not be committed
# Note: Videos, GT data and training datasets are hosted externally (see README)
data/*/
!data/eval_manifest.json

# Specifically ignore artifacts and results under data/
data/detected_moves/
data/detections/
!data/detections/*.pkl
data/figures/
data/results/
data/saved_h_cache/
data/training_images/
data/tmp/

# Models and training
models/yolo11_runs/
models/comparison_results/
datasets/

# Keep only the essential model if you want, otherwise keep all weights ignored
# !models/yolo11s_best_640.onnx
*.pt
*.onnx
*.tflite
*.engine
!models/scripts/
!models/scripts/**

# Generic artifacts
*.log
*.csv
*.yaml
*.json
!data/eval_manifest.json

# ============================
# VIDEO AND IMAGE CAPTURE
# ============================
*.mp4
*.mov
*.avi
*.mkv
*.jpg
*.jpeg
*.png
*.bmp
*.tiff

# ============================
# EXPERIMENT AND EVAL OUTPUTS
# ============================
output/
outputs/
eval/
evaluation/
tmp/
logs/
wandb/
tensorboard/
lightning_logs/
checkpoints/
__results__/

# ============================
# IDE AND EDITOR FILES
# ============================
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ============================
# SYSTEM FILES
# ============================
.DS_Store
Thumbs.db
desktop.ini

# ============================
# PRE COMMIT / DEV TOOLING
# ============================
.ruff_cache/
.pre-commit-config.yaml.bak

# ============================
# ENV / SECRETS
# ============================
.env
.env.*
*.env
.python-version

# ============================
# COVERAGE / REPORTS
# ============================
coverage.xml

