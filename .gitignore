# === BASE PYTHON / BUILD IGNORE ===
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
.eggs/
*.egg-info/
*.manifest
*.spec
htmlcov/
.tox/
.coverage*
.cache/
.pytest_cache/
.mypy_cache/
.pytype/
.dmypy.json
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# === JUPYTER / NOTEBOOKS ===
.ipynb_checkpoints/
*.nbconvert.ipynb
notebooks/.ipynb_checkpoints/
notebooks/.ipynb_cache/

# === DATA & MODEL FILES ===
# (Large or local-only data that should not be committed)
data/raw/
data/processed/
data/raw_images/
data/videos/
data/calibration/
data/labels/
data/tmp/
datasets/
models/
runs/
weights/
results/
*.pt               # YOLO weight files
*.onnx             # exported models
*.tflite
*.engine
*.log
*.csv              # generated evaluation logs
*.json             # generated predictions / eval outputs
*.yaml             # config exports (keep only your template)

# Project-specific training artifacts
training_data/

# Live run artifacts (game logs/moves)
src/pipeline/game_moves/*.log
src/pipeline/game_moves/*.txt
pipeline/game_moves/*.log
pipeline/game_moves/*.txt

# === VIDEO & IMAGE CAPTURE ===
*.mp4
*.mov
*.avi
*.mkv
*.jpg
*.jpeg
*.png
*.bmp
*.tiff

# === EXPERIMENT / EVAL OUTPUTS ===
output/
outputs/
eval/
evaluation/
tmp/
logs/
wandb/
tensorboard/
lightning_logs/
checkpoints/
__results__/

# === IDE / EDITOR ===
# VS Code, JetBrains, and others
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# === SYSTEM / OS SPECIFIC ===
.DS_Store
Thumbs.db
desktop.ini

# === PRE-COMMIT / DEV TOOLING ===
.ruff_cache/
.pre-commit-config.yaml.bak

# === ENV / SECRETS ===
.env
.env.*
*.env
.python-version

# === COVERAGE / REPORTS ===
coverage.xml

# === GIT-LFS (optional large files placeholder) ===
# *.pt filter=lfs diff=lfs merge=lfs -text
# *.mp4 filter=lfs diff=lfs merge=lfs -text

# === GLOBAL OVERRIDE: keep only src/ tracked ===
# Interpret request: only the src/ directory should be visible to Git by default.
# Existing tracked files are unaffected by .gitignore rules.
/*
!.gitignore
!/src/
!/src/**
/model_training/
/model_comparison/
