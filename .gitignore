# ============================
# PYTHON / BUILD ARTIFACTS
# ============================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
.eggs/
*.egg-info/
*.manifest
*.spec

# Test and coverage
htmlcov/
.tox/
.coverage*
.cache/
.pytest_cache/
.mypy_cache/
.pytype/
.dmypy.json

# Environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ============================
# JUPYTER / NOTEBOOKS
# ============================
.ipynb_checkpoints/
*.nbconvert.ipynb
notebooks/.ipynb_checkpoints/
notebooks/.ipynb_cache/

# ============================
# DATA AND MODELS
# ============================
# Large or local only data that should not be committed
data/raw/
data/gt/
data/images/
data/videos/
data/saved_h_cache/
data/labels/
data/tmp/
datasets/
models/comparison_results
!models/*
!models/scripts/
!models/scripts/**
runs/
weights/
results/

# Generic large binary artifacts
*.pt          # YOLO weight files
*.onnx        # exported models
*.tflite
*.engine
*.log
*.csv         # generated evaluation logs
*.json        # generated predictions or eval outputs
*.yaml        # config exports (keep only templates you need)

# Project specific training artifacts
training/yolo11_runs
training/yolo11_runs/*

# Live run artifacts (game detections and detected moves)
data/detected_moves/
!data/detections
!data/detections/*

# ============================
# VIDEO AND IMAGE CAPTURE
# ============================
*.mp4
*.mov
*.avi
*.mkv
*.jpg
*.jpeg
*.png
*.bmp
*.tiff

# ============================
# EXPERIMENT AND EVAL OUTPUTS
# ============================
output/
outputs/
eval/
evaluation/
tmp/
logs/
wandb/
tensorboard/
lightning_logs/
checkpoints/
__results__/

# ============================
# IDE AND EDITOR FILES
# ============================
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ============================
# SYSTEM FILES
# ============================
.DS_Store
Thumbs.db
desktop.ini

# ============================
# PRE COMMIT / DEV TOOLING
